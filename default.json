{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Default config to check every weekend",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":configMigration",
    ":pinDependencies",
    ":pinDevDependencies",
    ":semanticCommitTypeAll(chore)",
    "group:allNonMajor"
  ],
  "timezone": "Europe/Paris",
  "schedule": ["* 5-9 * * 6"],
  "postUpdateOptions": ["pnpmDedupe"],
  "abandonmentThreshold": "2 years",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 5-9 * * 6"]
  },
  "prHourlyLimit": 0,
  "reviewers": ["erwanjugand"],
  "labels": ["dependencies"],
  "commitBodyTable": true,
  "packageRules": [
    {
      "minimumReleaseAge": "1 day",
      "matchPackageNames": ["!@erwanjugand/*"]
    },
    {
      "groupName": "Font Awesome",
      "matchPackageNames": ["@fortawesome/**"],
      "matchUpdateTypes": ["major"]
    },
    {
      "matchPackageNames": ["stylelint**/**"],
      "matchUpdateTypes": ["major"],
      "schedule": ["at any time"]
    },
    {
      "matchPackageNames": ["@erwanjugand/eslint-config", "eslint"],
      "matchUpdateTypes": ["major"],
      "schedule": ["at any time"]
    },
    {
      "matchUpdateTypes": ["major"],
      "schedule": ["at any time"]
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["pnpm/action-setup"],
      "allowedVersions": "<6"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.*\\.yml$/"],
      "matchStrings": [
        "wranglerVersion:\\s*['\"]?(?<currentValue>[^'\"\\s]+)['\"]?"
      ],
      "depNameTemplate": "wrangler",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.nuxtrc$/"],
      "matchStrings": [
        "setups\\.@nuxt/test-utils=\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "@nuxt/test-utils",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    }
  ]
}
